# OpenRouter Configuration Template
# Copy this file to .env and fill in your API key

# OpenRouter API Endpoint
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Your OpenRouter API Key (get it from https://openrouter.ai/keys)
OPENAI_API_KEY=sk-or-v1-your-api-key-here

# Default Model (see https://openrouter.ai/models for available models)
DEFAULT_LLM_MODEL=qwen/qwen3.6-plus

# Alternative models:
# - anthropic/claude-3.5-sonnet
# - openai/gpt-4o
# - deepseek/deepseek-chat
# - meta-llama/llama-3.1-70b-instruct

# Semantic Scholar API Key (optional, for higher rate limits)
# Get it from: https://www.semanticscholar.org/product/api
# SEMANTIC_SCHOLAR_API_KEY=your-key-here

# PubMed / NCBI E-utilities (optional, increases rate limit from 3/s to 10/s)
# Get it from: https://www.ncbi.nlm.nih.gov/account/settings/
# PUBMED_API_KEY=your-ncbi-api-key-here
# PUBMED_EMAIL=your-email@example.com

# OpenAlex API (optional, polite pool = 10/s instead of 1/s)
# OPENALEX_EMAIL=your-email@example.com

# Crossref API (optional, polite pool)
# CROSSREF_EMAIL=your-email@example.com
